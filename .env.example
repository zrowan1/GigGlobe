# --- Database (self-hosted PostgreSQL) ---
# Connection string to your Postgres. Locally this points at the `db` service
# from docker-compose; in production it's the same compose network.
DATABASE_URL=postgres://gigglobe:gigglobe@localhost:5432/gigglobe

# --- Auth.js (NextAuth v5) ---
# Secret used to sign the session cookie (JWT). Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# Public URL of the app. Locally http://localhost:3000; in production your
# (sub)domain, e.g. https://gigglobe.example.com
AUTH_URL=http://localhost:3000

# --- Media storage ---
# Path to the folder (mounted volume) where uploaded photos/videos are stored.
# Locally a relative path like ./media is fine; in the container it's /media
# (the bind-mounted volume from docker-compose). The DB only stores paths
# relative to this folder.
MEDIA_DIR=./media

# Maximum upload size per file, in megabytes (optional; default 500).
MEDIA_MAX_UPLOAD_MB=500

# --- setlist.fm (optional) ---
# API key for looking up the setlist (songs played) of a gig. Get a free key at
# https://api.setlist.fm/docs/1.0/index.html (requires a setlist.fm account).
# Without a key the "Setlist ophalen" button simply shows "no setlist found".
SETLISTFM_API_KEY=
