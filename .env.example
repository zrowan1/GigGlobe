# --- Database (self-hosted PostgreSQL) ---
# The `db` service in docker-compose is created with these three values. Pick a
# strong password (compose refuses to start without POSTGRES_PASSWORD):
#   openssl rand -base64 24
POSTGRES_USER=gigglobe
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_DB=gigglobe

# Connection string used by `npm run db:migrate` and `npm run seed`, which run
# from the HOST against the localhost-bound port. The password here MUST match
# POSTGRES_PASSWORD above (this is the easiest thing to get wrong). The app
# itself doesn't use this value inside docker-compose — there it builds its own
# URL pointing at the `db` service (see docker-compose.yml).
DATABASE_URL=postgres://gigglobe:replace-me-with-a-strong-password@localhost:5432/gigglobe

# --- Auth.js (NextAuth v5) ---
# Secret used to sign the session cookie (JWT). Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# The exact address you open the app on in the browser. `localhost` only works
# when you browse ON the server itself — for LAN access use the server's address,
# e.g. http://<zimaos-host>:3000 or your VPN/Tailscale hostname. Behind a reverse
# proxy set it to your (sub)domain, e.g. https://gigglobe.example.com (the proxy +
# AUTH_TRUST_HOST=true then handle host detection). Getting this wrong breaks the
# login redirect when you sign in from another device.
AUTH_URL=http://localhost:3000

# --- Media storage ---
# Path to the folder (mounted volume) where uploaded photos/videos are stored.
# Locally a relative path like ./media is fine; in the container it's /media
# (the bind-mounted volume from docker-compose). The DB only stores paths
# relative to this folder.
MEDIA_DIR=./media

# Maximum upload size per file, in megabytes (optional; default 500).
MEDIA_MAX_UPLOAD_MB=500

# --- setlist.fm (optional) ---
# API key for looking up the setlist (songs played) of a gig. Get a free key at
# https://api.setlist.fm/docs/1.0/index.html (requires a setlist.fm account).
# Without a key the "Setlist ophalen" button simply shows "no setlist found".
SETLISTFM_API_KEY=
